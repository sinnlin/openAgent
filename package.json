{
  "name": "openAgent",
  "version": "1.0.0",
  "description": "TypeScript Agent System with Web Interface",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "clean": "shx rm -rf dist",
    "start": "node dist/index.js",
    "start:web": "node dist/index.js --web",
    "start:cli": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "dev:web": "ts-node src/index.ts --web",
    "dev:cli": "ts-node src/index.ts",
    "copy:public": "shx cp -r src/public dist/",
    "postbuild": "npm run copy:public"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "mathjs": "^11.11.0",
    "socket.io": "^4.6.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.8.7",
    "shx": "^0.4.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2"
  }
}
